# AIUndetect API (primary — dedicated humanizer)
# Get yours at https://www.aiundetect.com/api
AIUNDETECT_API_KEY=your-api-key-here
# Auto-Perfect mode (matches AIUndetect website default). Costs 2x words. Set to false to disable.
AIUNDETECT_AUTO=true

# Fallback: OpenRouter
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Fallback: OpenAI direct
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
